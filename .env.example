# ─── Server ───────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
WORK_DIR=./hls_work
PLAYLISTS_DIR=./playlists

# ─── HLS Processing ──────────────────────────────────
HLS_SEGMENT_DURATION=5
MAX_UPLOAD_SIZE_MB=500
MAX_IMAGE_UPLOAD_SIZE_MB=50

# ─── CDN Upload Credentials ──────────────────────────
# Replace these with your actual values
CDN_UPLOAD_ENDPOINT=https://your-cdn-endpoint.example.com/upload
CDN_CSRF_TOKEN=your_csrf_token_here
CDN_UUID=your-uuid-here
CDN_COOKIE=your_cookie_string_here

# ─── Logging ─────────────────────────────────────────
RUST_LOG=info
